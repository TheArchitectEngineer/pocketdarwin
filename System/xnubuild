#!/bin/bash

SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)
ROOT_DIR=$(cd "$SCRIPT_DIR/.." && pwd)
SRCROOT="$ROOT_DIR/System/xnu"
AVAILABILITY_PL="$ROOT_DIR/System/Patches/availability.pl"
RC_DARWIN_KERNEL_VERSION=${RC_DARWIN_KERNEL_VERSION:-$(uname -r)}

gmake -C "$SRCROOT" SDKROOT=$(xcrun --show-sdk-path) LOGCOLORS=y PLATFORM=MacOSX BUILD_LTO=0 BUILD_WERROR=0 DO_CTFMERGE=0 SRCROOT="$SRCROOT" BUILD_STATIC_LINK=1 AVAILABILITY_PL="$AVAILABILITY_PL" MACHINE=AEM64 AVAILABILITY_PL_PATH="$SDKROOT/usr/local/kernel" KERNEL_CONFIGS=DEVELOPMENT ARCH_CONFIGS=ARM64 VERBOSE=YES RC_DARWIN_KERNEL_VERSION="$RC_DARWIN_KERNEL_VERSION"
