#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")/../../../.." && pwd)"
SDK_ROOT="$ROOT_DIR/Developer/SDKs/PocketDarwin.sdk"
TARGET_TRIPLE="${PD_TARGET_TRIPLE:-arm64-apple-darwin}"

exec clang++ --target="$TARGET_TRIPLE" --sysroot="$SDK_ROOT" \
  -isystem "$SDK_ROOT/usr/include" \
  "$@"
