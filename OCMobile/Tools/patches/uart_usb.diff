+++ b/osfmk/console/serial_console.c
@@ -50,6 +50,15 @@ void serial_putc(char c)
     // UART putc
     uart_putc(c);
+
+    // PocketDarwin: Also output to USB UART
+    if (usb_uart_enabled) {
+        IOService::usbUartPutc(c);
+    }
+}
+
+static bool usb_uart_enabled = false;
+
+void enable_usb_uart(void)
+{
+    usb_uart_enabled = (IOService::usbUartInit() == kIOReturnSuccess);
