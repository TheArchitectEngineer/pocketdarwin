+// PocketDarwin: USB UART implementation
+IOReturn IOService::usbUartInit(void)
+{
+    // Initialize USB serial device
+    // Find USB controller, create serial interface
+    usb_serial = IOUSBDevice::findDevice("Android USB Serial");
+    if (usb_serial) {
+        usb_serial->open(this);
+        IOLog("PocketDarwin: USB UART initialized\n");
+        return kIOReturnSuccess;
+    }
+    return kIOReturnNotFound;
+}
+
+void IOService::usbUartPutc(char c)
+{
+    if (usb_serial) {
+        usb_serial->write(&c, 1);
+    }
+}
