diff --git a/osfmk/arm64/machine_routines.c b/osfmk/arm64/machine_routines.c
index 1234567..abcdef0 100644
--- a/osfmk/arm64/machine_routines.c
+++ b/osfmk/arm64/machine_routines.c
@@ -100,6 +100,15 @@ machine_init(void)
     // Initialize CPU
     cpu_init();
 
+    // PocketDarwin: Initialize internal screen framebuffer
+    // Map Android display memory
+    vm_offset_t fb_base = 0x7fc00000ULL; // From DT
+    vm_size_t fb_size = 0x00800000; // 8MB
+    fb_map = kmem_alloc(kernel_map, fb_size);
+    pmap_enter(kernel_pmap, fb_map, fb_base, VM_PROT_READ|VM_PROT_WRITE, 0);
+    // Set up console to use framebuffer
+    console_init_with_fb(fb_map, 1080, 1920);
+
     // Continue normal init
 }
 
@@ -200,6 +209,20 @@ void console_init(void)
 {
     // Default UART console
 }
 
+// PocketDarwin: Framebuffer console
+void console_init_with_fb(vm_offset_t fb, int width, int height)
+{
+    // Initialize framebuffer console
+    // Draw text on internal screen
+    fb_console_base = fb;
+    fb_width = width;
+    fb_height = height;
+    // Clear screen
+    memset((void*)fb, 0, width * height * 4);
+    // Set as primary console
+}
+
 // UART output
 void uart_putc(char c)
